{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile & Run with IO Files",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "g++ -std=c++17 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\" < \"${fileDirname}/input.txt\" > \"${fileDirname}/output.txt\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
